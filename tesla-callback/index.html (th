<!DOCTYPE html>
<html>
<head>
  <title>Rosey - Tesla Authorization</title>
  <style>
    body { font-family: -apple-system, sans-serif; text-align: center; padding: 60px 20px; background: #1a1a2e; color: #e0e0e0; }
    h1 { color: #a78bfa; }
    p { color: #9ca3af; margin-top: 20px; }
  </style>
  <script>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var code = params.get('code');
      var state = params.get('state');
      if (code) {
        var roseyURL = 'rosey://tesla-callback?code=' + encodeURIComponent(code);
        if (state) roseyURL += '&state=' + encodeURIComponent(state);
        window.location.href = roseyURL;
      }
    })();
  </script>
</head>
<body>
  <h1>Rosey</h1>
  <p>Redirecting to Rosey app...</p>
  <p>If nothing happens, make sure Rosey is running and <a href="#" onclick="window.location.reload()" style="color:#a78bfa">try again</a>.</p>
</body>
</html>
